# =============================================================================
# aws-cicd-qrcode-python-infra — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE / Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# AWS CLI & credentials — never commit these
# -----------------------------------------------------------------------------
.aws/
aws-exports.js
*.pem
*.key
credentials
config

# -----------------------------------------------------------------------------
# CloudFormation
# -----------------------------------------------------------------------------
# Packaged / transformed templates (output of `aws cloudformation package`)
*.packaged.yml
*.packaged.yaml
packaged-*.yml
packaged-*.yaml

# SAM build artifacts (if ever used alongside CFN)
.aws-sam/

# CDK (not used here, but guard against accidental init)
cdk.out/
cdk.context.json

# cfn-lint cache
.cfnlintrc.cache
.cfnlintrc

# taskcat output
.taskcat_outputs/
.taskcat.yml

# -----------------------------------------------------------------------------
# Linting / validation artefacts
# -----------------------------------------------------------------------------
.cfn-guard/
cfn-guard-output/

# -----------------------------------------------------------------------------
# Shell script artefacts
# -----------------------------------------------------------------------------
*.log
teardown.log

# -----------------------------------------------------------------------------
# Terraform (guard against accidental init in wrong repo)
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
*.tfplan

# -----------------------------------------------------------------------------
# Python (bootstrap helper scripts, if any)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/

# -----------------------------------------------------------------------------
# Node (guard against accidental npm init)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Secrets & environment files
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.secret
secrets.yml
secrets.yaml